# ========================
# SentinelAI .gitignore
# ========================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
venv/
.venv/
env/
.env
.env.local
.env.production
*.log

# ---- AI/ML ----
ai_engine/models/*.pkl
ai_engine/models/*.joblib
ai_engine/models/*.h5
ai_engine/datasets/*.csv
ai_engine/datasets/*.json
*.model

# ---- Node.js / Frontend ----
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Docker ----
docker/.env

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---- OS ----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Testing ----
.coverage
htmlcov/
.pytest_cache/
.tox/
.nox/

# ---- Misc ----
*.bak
*.tmp
*.temp
